# Vera Message Engine - Environment Variables Template
# Copy this file to .env and fill in your values

# Groq API Key (required) - Get from https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# LLM Provider (default: groq) - Options: groq, openai
LLM_PROVIDER=groq

# LLM Model (default: llama-3.3-70b-versatile)
# Groq models: llama-3.3-70b-versatile, llama-3.1-70b-versatile, mixtral-8x7b-32768
LLM_MODEL=llama-3.3-70b-versatile

# OpenAI API Key (optional fallback)
OPENAI_API_KEY=optional_fallback_key

# Bot Configuration
BOT_NAME=Vera Message Engine
BOT_VERSION=1.0.0

# Author Information
AUTHOR_NAME=Rakesh Penugonda
AUTHOR_EMAIL=rakeshwgpcgr@gmail.com

# Server Port (default: 8000)
PORT=8000